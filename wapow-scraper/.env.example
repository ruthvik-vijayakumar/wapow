# WAPOW Scraper Environment Variables

# MongoDB connection (required)
MONGODB_URI=mongodb://mongo:27017/wapow-data

# YouTube Data API v3 (optional - YouTube scraping disabled if not set)
# Get your API key at: https://console.cloud.google.com/
YOUTUBE_API_KEY=

# Spotify Web API (optional - Spotify scraping disabled if not set)
# Get credentials at: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Server settings (optional)
PORT=3003
DEBUG=false

# Scraping intervals in minutes (optional)
SCRAPE_INTERVAL_RSS=60
SCRAPE_INTERVAL_WEB=120
SCRAPE_INTERVAL_YOUTUBE=360
SCRAPE_INTERVAL_SPOTIFY=720

# Rate limiting (optional)
DEFAULT_RATE_LIMIT_DELAY=1.0
RESPECT_ROBOTS_TXT=true

# Content limits (optional)
MAX_ITEMS_PER_SOURCE=50

# Call wapow-app after each new article insert to generate story slides (optional)
# WAPOW_API_BASE_URL=http://localhost:3001
# STORY_CONVERT_ON_INGEST=false
