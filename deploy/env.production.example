# Copy to .env next to docker-compose.prod.yml on the Droplet (repo root).
# docker compose automatically loads .env for ${VAR} substitution.

# Required — DigitalOcean Container Registry (no trailing slash)
REGISTRY_PREFIX=registry.digitalocean.com/your-registry-name

# Optional overrides (defaults in compose work for internal Docker DNS)
# MONGODB_URI=mongodb://mongo:27017/wapow-data
# NEO4J_URI=neo4j://neo4j:7687
# NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-strong-password

# Auth0 (same audience as Vercel VITE_AUTH0_AUDIENCE)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://your-api-identifier

# Browsers calling API/collector from Vercel — comma-separated https origins
CORS_ORIGINS=https://tunedin.live,https://www.tunedin.live,https://your-app.vercel.app
