user  www-data;
worker_processes auto;

events {
    worker_connections 1024;
}

http {
    include       mime.types;
    default_type  application/octet-stream;

    sendfile        on;
    keepalive_timeout  65;

    # Docker embedded DNS — defer resolving Compose service names until request time
    resolver 127.0.0.11 ipv6=off valid=10s;

    # Default when hitting the Droplet by IP (SPA is hosted on Vercel)
    server {
        listen 80 default_server;
        server_name _;
        default_type text/plain;
        return 200 'wapow gateway — use api.* and collector.* hostnames\n';
    }

    # --- API: FastAPI (wapow-app) — service name: app ---
    server {
        listen 80;
        server_name api.tunedin.live;

        location ^~ /.well-known/acme-challenge/ {
            root /var/www/certbot;
            default_type text/plain;
        }

        location / {
            set $api_upstream http://app:3001;
            proxy_pass         $api_upstream;
            proxy_http_version 1.1;
            proxy_set_header   Host $host;
            proxy_set_header   X-Real-IP $remote_addr;
            proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header   X-Forwarded-Proto $scheme;
        }
    }

    # --- Analytics collector — service name: collector ---
    server {
        listen 80;
        server_name collector.tunedin.live;

        location ^~ /.well-known/acme-challenge/ {
            root /var/www/certbot;
            default_type text/plain;
        }

        location / {
            set $collector_upstream http://collector:3002;
            proxy_pass         $collector_upstream;
            proxy_http_version 1.1;
            proxy_set_header   Host $host;
            proxy_set_header   X-Real-IP $remote_addr;
            proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header   X-Forwarded-Proto $scheme;
        }
    }
}
