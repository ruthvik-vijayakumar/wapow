# API base URL (wapow-app backend)
# In production, set this to your public domain (no /api suffix) so the UI
# calls the same origin and Nginx proxies /api/* to the FastAPI service.
# Example:
# VITE_API_URL=https://wapow.example.com
VITE_API_URL=http://localhost:3001

# Content/articles/recommendations (legacy; prefer VITE_API_URL)
VITE_CONTENT_API=http://localhost:3001
VITE_ARTICLES_API=http://localhost:3001
VITE_RECOMMENDATIONS_API=http://localhost:3001

# Analytics collector
# In production, point this at the same origin and let Nginx proxy /collect/*
# to the collector service.
# Example:
# VITE_COLLECTOR_URL=https://wapow.example.com
VITE_COLLECTOR_URL=http://localhost:3002

# Auth0 (see wapow-app/docs/AUTH0_SETUP.md)
# Create SPA in Auth0 → Client ID, Domain
# Create API in Auth0 → Identifier (audience)
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-client-id
VITE_AUTH0_AUDIENCE=https://api.wapow.example.com
# Optional: override callback URL (default: origin/auth/callback; use if 0.0.0.0 causes issues)
# VITE_AUTH0_CALLBACK_URL=http://localhost:3000/auth/callback
